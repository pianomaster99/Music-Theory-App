rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}  (must equal the authenticated user's uid)
    // Fields:
    //   - displayName: string   (required, 1..40 chars)
    //   - createdAt:   timestamp (required, immutable)
    //   - updatedAt:   timestamp (optional)
    //
    // Subcollections under users/{uid} (per-user, owner-only):
    //   - progress/{lessonId}:
    //       - currentStepIndex: number  (required, 0..1000)
    //       - completedStepIds: list    (required, <=500 entries)
    //       - completed:        bool    (required)
    //       - updatedAt:        timestamp (required)
    //       - completedAt:      timestamp (optional)
    //   - stats/streak:
    //       - currentStreak: number    (required, 0..100000)
    //       - longestStreak: number    (required, 0..100000)
    //       - lastActiveDate: string   (required, YYYY-MM-DD)
    //       - updatedAt:      timestamp (required)
    //
    // NOTE: This is a prototype rule set. Review carefully before a
    // broad launch.
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProfile() {
      return request.resource.data.keys().hasOnly(['displayName', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(['displayName', 'createdAt'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.createdAt is timestamp;
    }

    function isValidStreak() {
      return request.resource.data.keys().hasOnly(['currentStreak', 'longestStreak', 'lastActiveDate', 'updatedAt'])
        && request.resource.data.keys().hasAll(['currentStreak', 'longestStreak', 'lastActiveDate', 'updatedAt'])
        && request.resource.data.currentStreak is number
        && request.resource.data.currentStreak >= 0
        && request.resource.data.currentStreak <= 100000
        && request.resource.data.longestStreak is number
        && request.resource.data.longestStreak >= 0
        && request.resource.data.longestStreak <= 100000
        && request.resource.data.lastActiveDate is string
        && request.resource.data.lastActiveDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidProgress() {
      return request.resource.data.keys().hasOnly(['currentStepIndex', 'completedStepIds', 'completed', 'updatedAt', 'completedAt'])
        && request.resource.data.keys().hasAll(['currentStepIndex', 'completedStepIds', 'completed', 'updatedAt'])
        && request.resource.data.currentStepIndex is number
        && request.resource.data.currentStepIndex >= 0
        && request.resource.data.currentStepIndex <= 1000
        && request.resource.data.completedStepIds is list
        && request.resource.data.completedStepIds.size() <= 500
        && request.resource.data.completed is bool
        && request.resource.data.updatedAt is timestamp
        && (!('completedAt' in request.resource.data) || request.resource.data.completedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile();
      allow update: if isOwner(userId)
        && isValidProfile()
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      // Per-user progress documents (owner-only, schema-validated).
      match /progress/{lessonId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProgress();
        allow delete: if false;
      }

      // Per-user streak document (owner-only, schema-validated).
      match /stats/streak {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidStreak();
        allow delete: if false;
      }
    }
  }
}
