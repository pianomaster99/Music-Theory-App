rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY TEST MODE: open access until 2026-07-23.
    // Replace with auth-based rules before shipping.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 23);
    }
  }
}
